# Painel Escuta (Next.js) — variáveis de ambiente.
# Copie para `.env.local` e ajuste. NÃO comite valores reais (.env.local é git-ignored).

# --- SERVER-SIDE (nunca vão ao browser) -------------------------------------
# Lidas só pelo proxy BFF em app/api/[...path]/route.ts.

# Base do backend FastAPI do Escuta. O proxy repassa cada chamada para
# `${ESCUTA_API_URL}/api/...`. Default quando ausente: http://localhost:8000
ESCUTA_API_URL=http://localhost:8000

# Chave da API do painel. Quando definida, o proxy injeta o header
# `X-Panel-Key: <valor>` em toda requisição ao backend. Em dev a API pode estar
# fail-open (sem checar a chave) — então deixar vazio também funciona localmente.
# Em prod, defina o MESMO valor que o backend espera. SEM prefixo NEXT_PUBLIC.
PANEL_API_KEY=

# --- CLIENT-SIDE (exposto ao browser — use com cuidado) ---------------------
# Base usada pelo cliente em lib/api.ts. DEIXE VAZIO em produção: assim as
# chamadas ficam relativas (/api/...) e passam pelo proxy BFF acima (a chave
# fica no servidor). Só preencha (ex.: http://localhost:8000) para debugar o
# front falando DIRETO com o backend, contornando o proxy.
NEXT_PUBLIC_API_URL=
