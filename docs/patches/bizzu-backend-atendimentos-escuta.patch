+
+  /**
+   * Captura evento de TICKET / contato público (pode não ter userId): manda o
+   * telefone direto, sem resolver o User. Mesmo HMAC + fire-and-forget.
+   */
+  captureForTicket(
+    phone: string | null,
+    event: string,
+    eventId: string | null,
+    properties: EscutaCaptureProperties = {},
+  ): void {
+    if (!this.baseUrl || !this.secret) {
+      return;
+    }
+    if (!phone) {
+      this.logger.log(`[escuta] ticket event '${event}' sem telefone — pulando`);
+      return;
+    }
+    void this.sendForTicket(phone, event, eventId, properties).catch((err) => {
+      this.logger.warn(
+        `Failed to send '${event}' to Escuta: ${err instanceof Error ? err.message : String(err)}`,
+      );
+    });
+  }
+
+  private async sendForTicket(
+    phone: string,
+    event: string,
+    eventId: string | null,
+    properties: EscutaCaptureProperties,
+  ): Promise<void> {
+    const body = JSON.stringify({
+      event,
+      event_id: eventId,
+      user: {
+        id: null,
+        name: typeof properties.nome === 'string' ? properties.nome : null,
+        phone,
+        whatsapp_opt_in: false,
+      },
+      properties,
+    });
+    const timestamp = Math.floor(Date.now() / 1000).toString();
+    const signature = createHmac('sha256', this.secret as string)
+      .update(`${timestamp}.${body}`)
+      .digest('hex');
+    const response = await fetch(`${this.baseUrl}/api/events/bizzu`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        'X-Escuta-Timestamp': timestamp,
+        'X-Escuta-Signature': signature,
+      },
+      body,
+      signal: AbortSignal.timeout(5000),
+    });
+    if (!response.ok) {
+      const detail = await response.text().catch(() => '');
+      throw new Error(`Escuta responded ${response.status}: ${detail.slice(0, 200)}`);
+    }
+    this.logger.log(`[escuta] '${event}' phone=${phone} sent`);
+  }
 }

