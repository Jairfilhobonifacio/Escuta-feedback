 import { ExternalQuestionSession } from '../plano-estudo-ia/models/external-question-session.model';
 import { StudyPlanSnapshotTask } from '../plano-estudo-ia/models/study-plan-snapshot-task.model';
 import { StudyPlanSnapshotGoal } from '../plano-estudo-ia/models/study-plan-snapshot-goal.model';
@@ -29,6 +30,7 @@
     @InjectModel(PlanoEstudoQuestao)
     private readonly planoEstudoQuestaoModel: typeof PlanoEstudoQuestao,
+    private readonly escuta: EscutaService,
   ) {}

   async check(userId: string): Promise<{ trigger: string } | null> {
@@ -91,12 +93,22 @@
   async submit(
     userId: string,
     trigger: string,
     score: number | null,
     comment: string | null,
   ): Promise<void> {
     const existing = await this.npsResponseModel.findOne({ where: { userId, trigger } });
+    let responseId: string;
     if (existing) {
       await existing.update({ score, comment });
+      responseId = existing.id;
     } else {
-      await this.npsResponseModel.create({ userId, trigger, score, comment } as CreationAttributes<NpsResponse>);
+      const created = await this.npsResponseModel.create(
+        { userId, trigger, score, comment } as CreationAttributes<NpsResponse>,
+      );
+      responseId = created.id;
     }
+
+    // Espelha o NPS in-app no Escuta (modo ingest — sem disparo de WhatsApp).
+    // Fire-and-forget: nunca bloqueia nem quebra o submit do NPS.
+    this.escuta.captureForUser(userId, 'nps_submitted', `nps:${responseId}`, {
+      trigger,
+      score,
+      comment,
+    });
   }
 }
