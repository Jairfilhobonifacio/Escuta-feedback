diff --git a/src/users/users.service.updateProfile.spec.ts b/src/users/users.service.updateProfile.spec.ts
new file mode 100644
index 0000000..f66470e
--- /dev/null
+++ b/src/users/users.service.updateProfile.spec.ts
@@ -0,0 +1,189 @@
+/**
+ * Tests for UsersService.updateProfile — regras do consentimento de WhatsApp
+ * (Escuta / Central de Feedbacks), via PATCH /user/me.
+ *
+ * Regras:
+ *   - Ligar (whatsappOptIn: true) exige telefone preenchido → BadRequest sem.
+ *   - Ao ligar, carimba whatsappOptInAt = new Date() (só na transição OFF→ON;
+ *     reenviar true quando já ligado preserva o carimbo original do
+ *     consentimento).
+ *   - Ao desligar, whatsappOptIn = false e whatsappOptInAt = null.
+ *   - Telefone enviado no MESMO request conta para a regra (campos são
+ *     aplicados antes da checagem) — tanto para adicionar quanto remover.
+ *
+ * Mocks de estáticos de User/Subscription no padrão dos specs vizinhos
+ * (users.service.setPlan.spec.ts). Sem DB.
+ */
+import { BadRequestException } from '@nestjs/common';
+import { UsersService } from './users.service';
+import { User } from './user.model';
+import { Subscription } from '../payments/subscription.model';
+import type { PlanosService } from '../planos/planos.service';
+import type { CpfEncryptionService } from '../crypto/cpf-encryption.service';
+
+const PHONE = '+5524998365809';
+
+function makeFakeUserInstance(initial: Record<string, unknown> = {}) {
+  const state: Record<string, unknown> = {
+    id: 'user-1',
+    primeiroNome: 'Jair',
+    ultimoNome: 'E2E',
+    email: 'jair.e2e@escuta.test',
+    phoneNumber: null,
+    planoId: null,
+    pendingPlanoId: null,
+    role: 'CANDIDATE',
+    cpfEncrypted: null,
+    passwordHash: null,
+    whatsappOptIn: false,
+    whatsappOptInAt: null,
+    ...initial,
+  };
+  const save = jest.fn().mockResolvedValue(undefined);
+  const instance: Record<string, unknown> = {
+    get: (_opts?: unknown) => ({ ...state }),
+    save,
+  };
+  // Getters/setters espelhando `state` para que as atribuições do service
+  // (user.phoneNumber = ..., user.whatsappOptIn = ...) fiquem visíveis no
+  // `get({ plain: true })` usado pelo getMe/toUserPublic.
+  for (const key of Object.keys(state)) {
+    Object.defineProperty(instance, key, {
+      get: () => state[key],
+      set: (v: unknown) => {
+        state[key] = v;
+      },
+      enumerable: true,
+    });
+  }
+  return { instance, state, save };
+}
+
+function mockReads(instance: unknown) {
+  jest.spyOn(User, 'findByPk').mockResolvedValue(instance as never);
+  // getMe roundtrip pós-save
+  jest.spyOn(User, 'unscoped').mockReturnValue({
+    findByPk: jest.fn().mockResolvedValue(instance),
+  } as never);
+  jest.spyOn(Subscription, 'findOne').mockResolvedValue(null as never);
+}
+
+describe('UsersService.updateProfile — consentimento de WhatsApp', () => {
+  let service: UsersService;
+
+  beforeEach(() => {
+    service = new UsersService(
+      {} as PlanosService,
+      {} as CpfEncryptionService,
+    );
+  });
+
+  afterEach(() => {
+    jest.restoreAllMocks();
+  });
+
+  it('liga com telefone: ativa e carimba whatsappOptInAt', async () => {
+    const { instance, state, save } = makeFakeUserInstance({
+      phoneNumber: PHONE,
+    });
+    mockReads(instance);
+    const before = Date.now();
+
+    const result = await service.updateProfile('user-1', { whatsappOptIn: true });
+
+    expect(state.whatsappOptIn).toBe(true);
+    expect(state.whatsappOptInAt).toBeInstanceOf(Date);
+    expect((state.whatsappOptInAt as Date).getTime()).toBeGreaterThanOrEqual(before);
+    expect(save).toHaveBeenCalled();
+    // exposto no payload público (frontend lê o estado atual daqui)
+    expect(result!.whatsappOptIn).toBe(true);
+    expect(result!.whatsappOptInAt).toBeInstanceOf(Date);
+  });
+
+  it('liga sem telefone: rejeita com BadRequestException e não salva', async () => {
+    const { instance, state, save } = makeFakeUserInstance({
+      phoneNumber: null,
+    });
+    mockReads(instance);
+
+    await expect(
+      service.updateProfile('user-1', { whatsappOptIn: true }),
+    ).rejects.toBeInstanceOf(BadRequestException);
+
+    expect(state.whatsappOptIn).toBe(false);
+    expect(state.whatsappOptInAt).toBeNull();
+    expect(save).not.toHaveBeenCalled();
+  });
+
+  it('desliga: limpa o carimbo', async () => {
+    const { instance, state, save } = makeFakeUserInstance({
+      phoneNumber: PHONE,
+      whatsappOptIn: true,
+      whatsappOptInAt: new Date('2026-06-01T12:00:00Z'),
+    });
+    mockReads(instance);
+
+    const result = await service.updateProfile('user-1', { whatsappOptIn: false });
+
+    expect(state.whatsappOptIn).toBe(false);
+    expect(state.whatsappOptInAt).toBeNull();
+    expect(save).toHaveBeenCalled();
+    expect(result!.whatsappOptIn).toBe(false);
+    expect(result!.whatsappOptInAt).toBeNull();
+  });
+
+  it('liga junto com telefone novo no mesmo request: aceita', async () => {
+    const { instance, state } = makeFakeUserInstance({ phoneNumber: null });
+    mockReads(instance);
+
+    await service.updateProfile('user-1', {
+      phoneNumber: PHONE,
+      whatsappOptIn: true,
+    });
+
+    expect(state.phoneNumber).toBe(PHONE);
+    expect(state.whatsappOptIn).toBe(true);
+    expect(state.whatsappOptInAt).toBeInstanceOf(Date);
+  });
+
+  it('remover telefone e ligar no mesmo request: rejeita', async () => {
+    const { instance, save } = makeFakeUserInstance({ phoneNumber: PHONE });
+    mockReads(instance);
+
+    await expect(
+      service.updateProfile('user-1', { phoneNumber: null, whatsappOptIn: true }),
+    ).rejects.toBeInstanceOf(BadRequestException);
+    expect(save).not.toHaveBeenCalled();
+  });
+
+  it('reenviar true quando já ligado preserva o carimbo original', async () => {
+    const original = new Date('2026-06-01T12:00:00Z');
+    const { instance, state } = makeFakeUserInstance({
+      phoneNumber: PHONE,
+      whatsappOptIn: true,
+      whatsappOptInAt: original,
+    });
+    mockReads(instance);
+
+    await service.updateProfile('user-1', { whatsappOptIn: true });
+
+    expect(state.whatsappOptIn).toBe(true);
+    expect(state.whatsappOptInAt).toBe(original);
+  });
+
+  it('request sem whatsappOptIn não mexe no consentimento', async () => {
+    const original = new Date('2026-06-01T12:00:00Z');
+    const { instance, state } = makeFakeUserInstance({
+      phoneNumber: PHONE,
+      whatsappOptIn: true,
+      whatsappOptInAt: original,
+    });
+    mockReads(instance);
+
+    await service.updateProfile('user-1', { primeiroNome: 'NovoNome' });
+
+    expect(state.primeiroNome).toBe('NovoNome');
+    expect(state.whatsappOptIn).toBe(true);
+    expect(state.whatsappOptInAt).toBe(original);
+  });
+});
