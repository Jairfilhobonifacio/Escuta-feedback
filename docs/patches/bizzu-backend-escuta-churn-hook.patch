+'use strict';
+
+/**
+ * Escuta (Central de Feedbacks via WhatsApp) — opt-in dedicado de WhatsApp.
+ *
+ * Até aqui a integração usava `!marketingOptOut` como proxy de consentimento.
+ * WhatsApp é um canal mais invasivo que email: consentimento específico
+ * (LGPD art. 8º §4º — finalidades determinadas) e auditável.
+ *
+ * Espelha o par `marketingOptOut`/`marketingOptOutAt` já existente:
+ *  - usuarios.whatsappOptIn   — BOOLEAN NOT NULL DEFAULT false (ninguém é
+ *    inscrito retroativamente; só novos consentimentos explícitos).
+ *  - usuarios.whatsappOptInAt — TIMESTAMPTZ nullable, carimbo do consentimento
+ *    (auditoria; null quando nunca consentiu ou após revogação).
+ *
+ * Additive-column migration: segue o idioma do repo (sem transaction wrap
+ * explícito — ver 20260603120100-add-radar-tracking-columns.js).
+ */
+module.exports = {
+  async up(queryInterface, Sequelize) {
+    await queryInterface.addColumn('usuarios', 'whatsappOptIn', {
+      type: Sequelize.BOOLEAN,
+      allowNull: false,
+      defaultValue: false,
+    });
+    await queryInterface.addColumn('usuarios', 'whatsappOptInAt', {
+      type: Sequelize.DATE,
+      allowNull: true,
+    });
+  },
+
+  async down(queryInterface) {
+    await queryInterface.removeColumn('usuarios', 'whatsappOptInAt');
+    await queryInterface.removeColumn('usuarios', 'whatsappOptIn');
+  },
+};
