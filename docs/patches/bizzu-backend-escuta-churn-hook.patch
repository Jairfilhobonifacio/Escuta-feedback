@@ -0,0 +1,17 @@
+import { Module, Global } from '@nestjs/common';
+import { SequelizeModule } from '@nestjs/sequelize';
+import { EscutaService } from './escuta.service';
+import { User } from '../users/user.model';
+
+/**
+ * Integração com a Central de Feedbacks (Escuta) — eventos de ciclo de vida
+ * via WhatsApp. Global como o TrackingModule: qualquer service injeta
+ * EscutaService sem importar o módulo.
+ */
+@Global()
+@Module({
+  imports: [SequelizeModule.forFeature([User])],
+  providers: [EscutaService],
+  exports: [EscutaService],
+})
+export class EscutaModule {}
diff --git a/src/escuta/escuta.service.ts b/src/escuta/escuta.service.ts
new file mode 100644
index 0000000..48f469e
--- /dev/null
+++ b/src/escuta/escuta.service.ts
@@ -0,0 +1,124 @@
+import { Injectable, Logger } from '@nestjs/common';
+import { InjectModel } from '@nestjs/sequelize';
+import { createHmac } from 'crypto';
+import { User } from '../users/user.model';
+
+/**
+ * Adapter de eventos de ciclo de vida para a Central de Feedbacks (Escuta).
+ *
+ * Espelha o padrão do PosthogTrackingService: desabilitado graciosamente quando
+ * as envs não estão configuradas, e `captureForUser` NUNCA lança nem bloqueia o
+ * fluxo chamador (fire-and-forget) — cancelamento de assinatura não pode falhar
+ * por causa de telemetria/feedback.
+ *
+ * Autenticação: HMAC-SHA256 do corpo cru com segredo compartilhado, no formato
+ * assinatura = hmac(secret, `${timestamp}.${body}`) — verificado pelo Escuta em
+ * POST /api/events/bizzu.
+ */
+export interface EscutaCaptureProperties {
+  [key: string]: unknown;
+}
+
+@Injectable()
+export class EscutaService {
+  private readonly logger = new Logger(EscutaService.name);
+  private readonly baseUrl: string | null;
+  private readonly secret: string | null;
+
+  constructor(
+    @InjectModel(User)
+    private readonly userModel: typeof User,
+  ) {
+    this.baseUrl = process.env.ESCUTA_API_URL ?? null;
+    this.secret = process.env.ESCUTA_WEBHOOK_SECRET ?? null;
+    if (!this.baseUrl || !this.secret) {
+      this.logger.warn(
+        'ESCUTA_API_URL/ESCUTA_WEBHOOK_SECRET not set — Escuta lifecycle events disabled',
+      );
+    }
+  }
+
+  /**
+   * Envia um evento de ciclo de vida do usuário para o Escuta.
+   *
+   * @param userId   id do usuário (o telefone/nome são resolvidos aqui)
+   * @param event    nome do evento (ex.: 'subscription_cancelled')
+   * @param eventId  id estável para idempotência (ex.: `sub:${externalSubscriptionId}`)
+   */
+  captureForUser(
+    userId: string,
+    event: string,
+    eventId: string | null,
+    properties: EscutaCaptureProperties = {},
+  ): void {
+    if (!this.baseUrl || !this.secret) {
+      return;
+    }
+    void this.send(userId, event, eventId, properties).catch((err) => {
+      this.logger.warn(
+        `Failed to send '${event}' to Escuta: ${err instanceof Error ? err.message : String(err)}`,
+      );
+    });
+  }
+
+  private async send(
+    userId: string,
+    event: string,
+    eventId: string | null,
+    properties: EscutaCaptureProperties,
+  ): Promise<void> {
+    const user = await this.userModel.findByPk(userId);
+    if (!user) {
+      this.logger.warn(`[escuta] user ${userId} not found — skipping '${event}'`);
+      return;
+    }
+    if (!user.phoneNumber) {
+      this.logger.log(`[escuta] user ${userId} has no phone — skipping '${event}'`);
+      return;
+    }
+
+    const body = JSON.stringify({
+      event,
+      event_id: eventId,
+      user: {
+        id: user.id,
+        name: `${user.primeiroNome} ${user.ultimoNome}`.trim(),
+        phone: user.phoneNumber,
+        // Consentimento específico de WhatsApp (capturado no signup/conta).
+        whatsapp_opt_in: user.whatsappOptIn,
+      },
+      properties,
+    });
+
+    const timestamp = Math.floor(Date.now() / 1000).toString();
+    const signature = createHmac('sha256', this.secret as string)
+      .update(`${timestamp}.${body}`)
+      .digest('hex');
+
+    const response = await fetch(`${this.baseUrl}/api/events/bizzu`, {
+      method: 'POST',
+      headers: {
+        'Content-Type': 'application/json',
+        'X-Escuta-Timestamp': timestamp,
+        'X-Escuta-Signature': signature,
+      },
+      body,
+      signal: AbortSignal.timeout(5000),
+    });
+
+    if (!response.ok) {
+      const detail = await response.text().catch(() => '');
+      throw new Error(`Escuta responded ${response.status}: ${detail.slice(0, 200)}`);
+    }
+
+    const result = (await response.json().catch(() => null)) as {
+      dispatched?: boolean;
+      reason?: string;
+    } | null;
+    this.logger.log(
+      `[escuta] '${event}' user=${userId} dispatched=${result?.dispatched ?? '?'}${
+        result?.reason ? ` reason=${result.reason}` : ''
+      }`,
+    );
+  }
+}
