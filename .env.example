# Escuta — variáveis de ambiente (copie para .env e preencha)
# O .env é carregado automaticamente pelos scripts se python-dotenv estiver instalado.

# Banco de dados (Supabase) — driver async. Obrigatório para o app e o seed.
# Formato: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db

# Gateway WAHA (WhatsApp HTTP API)
WAHA_BASE_URL=http://localhost:3000
WAHA_API_KEY=
WAHA_SESSION=default

# Org do piloto (slug padrão)
DEFAULT_ORG_SLUG=bizzu

# API de Clientes da Bizzu (parceiro) - peca a chave ao Felipe
BIZZU_PARTNER_API_URL=https://api.bizzu.ai
BIZZU_PARTNER_API_KEY=

# Postgres da Bizzu (usado por scripts/sync_bizzu_contacts.py). Contém senha:
# preencha aqui, nunca commite o valor. Ex.: postgresql://USER:SENHA@localhost:5432/plataforma
BIZZU_DATABASE_URL=
